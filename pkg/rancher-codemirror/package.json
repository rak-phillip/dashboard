{
  "name": "@rancher/codemirror",
  "version": "0.3.1",
  "description": "Vue 3 CodeMirror 6 component library",
  "type": "module",
  "main": "./dist/rancher-codemirror.umd.cjs",
  "module": "./dist/rancher-codemirror.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/rancher-codemirror.js",
      "require": "./dist/rancher-codemirror.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --project tsconfig.build.json --declaration --emitDeclarationOnly --outDir dist && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.0.0",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/lang-json": "^6.0.0",
    "@codemirror/lang-yaml": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/lint": "^6.0.0",
    "@codemirror/search": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/theme-one-dark": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@replit/codemirror-vim": "^6.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "^5.3.0",
    "vite": "^7.0.0",
    "vue": "^3.4.0",
    "vue-tsc": "^3.0.0"
  }
}
